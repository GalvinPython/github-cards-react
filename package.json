{
    "name": "github-cards-react",
    "version": "0.2.1",
    "description": "Lightweight React component for displaying GitHub repository cards.",
    "license": "MIT",
    "author": "GalvinPython",
    "homepage": "https://github.com/galvinpython/github-cards-react",
    "repository": {
        "type": "git",
        "url": "https://github.com/galvinpython/github-cards-react.git"
    },
    "bugs": {
        "url": "https://github.com/galvinpython/github-cards-react/issues"
    },
    "keywords": [
        "react",
        "github",
        "card",
        "component",
        "ui",
        "typescript"
    ],
    "sideEffects": false,
    "files": [
        "dist"
    ],
    "engines": {
        "node": ">=20.19.0"
    },
    "main": "./dist/index.cjs",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js",
            "require": "./dist/index.cjs"
        }
    },
    "scripts": {
        "build": "tsdown",
        "dev": "tsdown --watch",
        "typecheck": "tsc --noEmit"
    },
    "peerDependencies": {
        "react": ">=18",
        "react-dom": ">=18"
    },
    "devDependencies": {
        "@types/react": "^18.0.0",
        "@types/react-dom": "^18.0.0",
        "tsdown": "^0.21.7",
        "typescript": "^6.0.2"
    },
    "type": "module",
    "dependencies": {
        "@primer/octicons-react": "^19.22.0",
        "linguist-colors-list": "^1.0.20260223"
    }
}