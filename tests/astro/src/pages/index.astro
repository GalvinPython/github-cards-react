---
import { GithubCard, GithubCardDummy } from "../../../../src/GithubCard";
Astro.response.headers.set(
  "Cache-Control",
  "public, max-age=3600, s-maxage=3600",
);
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>Astro</title>
    <style>
      body {
        font-family:
          system-ui,
          -apple-system,
          BlinkMacSystemFont,
          "Segoe UI",
          Roboto,
          Oxygen,
          Ubuntu,
          Cantarell,
          "Open Sans",
          "Helvetica Neue",
          sans-serif;
        background: #111;
        color: #fff;
      }
    </style>
  </head>
  <body>
    <h1>Astro Test</h1>
    <p>Dark</p>
    <GithubCardDummy
      username="galvinpython"
      data={{
        name: "github-cards-react",
        description: "A GitHub dummy card in dark mode! This one has topics",
        html_url: "https://github.com/galvinpython/github-cards-react",
        stargazers_count: 999,
        forks_count: 123,
        language: "TypeScript",
        topics: ["react", "github", "card", "component"],
        owner: {
          avatar_url: "https://avatars.githubusercontent.com/u/77013913?v=4",
        },
        languages: {
          TypeScript: 174221,
          JavaScript: 15710,
          Astro: 6046,
          Shell: 3769,
          Rust: 3685,
          CSS: 2056,
          Makefile: 145,
        },
      }}
      theme="dark"
      client:only="react"
    />
    <p>Light</p>
    <GithubCardDummy
      username="galvinpython"
      data={{
        name: "github-cards-react",
        description:
          "A GitHub dummy card in light mode! Apparently this one is in Rust now",
        html_url: "https://github.com/galvinpython/github-cards-react",
        stargazers_count: 999,
        forks_count: 123,
        language: "Rust",
        // topics: ["react", "github", "card", "component"],
        owner: {
          avatar_url: "https://avatars.githubusercontent.com/u/77013913?v=4",
        },
      }}
      theme="light"
      client:only="react"
    />

    <p>Real API Test</p>
    <GithubCard
      username="chromium"
      repo="chromium"
      theme="dark"
      showLanguagesBar={true}
      client:load
    />
  </body>
</html>
